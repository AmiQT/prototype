# Environment Variables untuk Vercel Deployment

# Backend URL - Update ini selepas deploy backend
BACKEND_URL=https://your-backend-url.railway.app

# Cara Set di Vercel:
# 1. Pergi ke Vercel Dashboard
# 2. Select project: student-talent-profiling-app
# 3. Settings > Environment Variables
# 4. Add: BACKEND_URL = <your-backend-url>
# 5. Redeploy: vercel --prod
